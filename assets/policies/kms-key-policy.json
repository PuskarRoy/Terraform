{
	"Id": "key-consolepolicy-3",
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "Enable IAM User Permissions",
			"Effect": "Allow",
			"Principal": {
				"AWS": "arn:aws:iam::388458311239:root"
			},
			"Action": "kms:*",
			"Resource": "*"
		},
		{
			"Sid": "Allow access for Key Administrators",
			"Effect": "Allow",
			"Principal": {
				"AWS": [
					"arn:aws:iam::388458311239:user/Boto3",
					"arn:aws:iam::388458311239:user/terraform",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationAgentRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationConversionServerRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationLaunchInstanceWithDrsRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationLaunchInstanceWithSsmRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationMGHRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationReplicationServerRole",
					"arn:aws:iam::388458311239:role/aws-service-role/mgn.amazonaws.com/AWSServiceRoleForApplicationMigrationService",
					"arn:aws:iam::388458311239:role/aws-service-role/events.amazonaws.com/AWSServiceRoleForCloudWatchEvents"
				]
			},
			"Action": [
				"kms:Create*",
				"kms:Describe*",
				"kms:Enable*",
				"kms:List*",
				"kms:Put*",
				"kms:Update*",
				"kms:Revoke*",
				"kms:Disable*",
				"kms:Get*",
				"kms:Delete*",
				"kms:TagResource",
				"kms:UntagResource",
				"kms:ScheduleKeyDeletion",
				"kms:CancelKeyDeletion",
				"kms:RotateKeyOnDemand"
			],
			"Resource": "*"
		},
		{
			"Sid": "Allow use of the key",
			"Effect": "Allow",
			"Principal": {
				"AWS": [
					"arn:aws:iam::388458311239:user/Boto3",
					"arn:aws:iam::388458311239:user/terraform",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationAgentRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationConversionServerRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationLaunchInstanceWithDrsRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationLaunchInstanceWithSsmRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationMGHRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationReplicationServerRole",
					"arn:aws:iam::388458311239:role/aws-service-role/mgn.amazonaws.com/AWSServiceRoleForApplicationMigrationService",
					"arn:aws:iam::388458311239:role/aws-service-role/events.amazonaws.com/AWSServiceRoleForCloudWatchEvents"
				]
			},
			"Action": [
				"kms:Encrypt",
				"kms:Decrypt",
				"kms:ReEncrypt*",
				"kms:GenerateDataKey*",
				"kms:DescribeKey"
			],
			"Resource": "*"
		},
		{
			"Sid": "Allow attachment of persistent resources",
			"Effect": "Allow",
			"Principal": {
				"AWS": [
					"arn:aws:iam::388458311239:user/Boto3",
					"arn:aws:iam::388458311239:user/terraform",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationAgentRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationConversionServerRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationLaunchInstanceWithDrsRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationLaunchInstanceWithSsmRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationMGHRole",
					"arn:aws:iam::388458311239:role/service-role/AWSApplicationMigrationReplicationServerRole",
					"arn:aws:iam::388458311239:role/aws-service-role/mgn.amazonaws.com/AWSServiceRoleForApplicationMigrationService",
					"arn:aws:iam::388458311239:role/aws-service-role/events.amazonaws.com/AWSServiceRoleForCloudWatchEvents"
				]
			},
			"Action": [
				"kms:CreateGrant",
				"kms:ListGrants",
				"kms:RevokeGrant"
			],
			"Resource": "*",
			"Condition": {
				"Bool": {
					"kms:GrantIsForAWSResource": "true"
				}
			}
		},

		{
  "Sid": "Allow EC2 to use the key",
  "Effect": "Allow",
  "Principal": {
    "AWS": "arn:aws:iam::388458311239:root"
  },
  "Action": [
    "kms:CreateGrant",
    "kms:Decrypt",
    "kms:DescribeKey",
    "kms:GenerateDataKeyWithoutPlaintext",
    "kms:ReEncrypt"
  ],
  "Resource": "*"
}
	]
}